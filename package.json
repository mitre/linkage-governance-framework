{
  "name": "cgf-visual-model",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "npm run assets:build && npx @11ty/eleventy",
    "build-ghpages" : "npx @11ty/eleventy --pathprefix=/linkage-governance-framework/",
    "clean": "rimraf public",
    "assets:autoprefix": "postcss public/assets/styles/*.css -r --use autoprefixer",
    "assets:build": "node ./config/buildAssets && npm run assets:autoprefix",
    "assets:clean": "rimraf public/assets",
    "assets:refresh": "npm run assets:clean && npm run assets:build",
    "assets:watch": "chokidar 'assets/' -c 'npm run assets:refresh' --polling",
    "dev": "npm run clean && npm-run-all -p dev:assets dev:serve",
    "dev:clean": "npm run clean && npm run dev",
    "dev:assets": "npm run assets:refresh && npm run assets:watch",
    "dev:debug": "DEBUG=* npx @11ty/eleventy --serve --watch",
    "dev:serve": "npx @11ty/eleventy --serve --watch",
    "test": "echo \"Error: no test specified\" && exit 1",
    "serve": "npx @11ty/eleventy --serve",
    "start": "npx --node-options='--experimental-require-module' @11ty/eleventy --serve"
  },
  "keywords": [],
  "author": "",
  "license": "CC0-1.0",
  "type": "commonjs",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "chai": "^6.2.1",
    "check-html-links": "^0.2.4",
    "chokidar-cli": "^3.0.0",
    "js-yaml": "^4.1.1",
    "jsdom": "^27.2.0",
    "markdown-it": "^14.1.1",
    "markdown-it-attrs": "^4.3.1",
    "markdown-it-deflist": "^3.0.0",
    "mocha": "^11.7.5",
    "npm-run-all": "^4.1.5",
    "pa11y-ci": "^4.0.1",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "rimraf": "^6.1.2"
  },
  "dependencies": {
    "@11ty/eleventy-fetch": "^5.1.1",
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-navigation": "^1.0.5",
    "@uswds/uswds": "^3.13.0",
    "autoprefixer": "^10.4.22",
    "dotenv": "^17.2.3",
    "eleventy-plugin-toc": "^1.1.5",
    "esbuild": "^0.27.1",
    "esbuild-sass-plugin": "^3.3.1",
    "markdown-it-footnote": "^4.0.0"
  }
}
